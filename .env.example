# ============================================================
# OTT Curation App - 환경변수 설정
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요
# ============================================================

# GCP 설정
GCP_PROJECT_ID=ott-curation-app
GCP_REGION=asia-northeast3
GCP_SQL_INSTANCE_NAME=ott-curation-db

# 데이터베이스
DB_NAME=ott_curation
DB_USER=ott_app
DB_PASSWORD=your_secure_password_here

# Firebase
FIREBASE_PROJECT_ID=ott-curation-app

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voyage AI (임베딩)
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# TMDb (콘텐츠 메타데이터)
TMDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TMDB_API_READ_ACCESS_TOKEN=eyJxxxxxxxxxxxxxxxxxx

# JustWatch (OTT 가용성 데이터)
# 공식 파트너 API가 없을 경우 아래를 비워두면 비공식 API 사용
JUSTWATCH_API_KEY=

# 서버 설정
PORT=8080
NODE_ENV=development
API_SECRET_KEY=your_internal_api_secret_here

# Cloud Storage 버킷명
GCS_VIDEO_BUCKET=ott-curation-ai-videos
GCS_THUMBNAIL_BUCKET=ott-curation-thumbnails
GCS_AVATAR_BUCKET=ott-curation-avatars
